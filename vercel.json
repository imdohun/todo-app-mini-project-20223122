{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/todos/:id", "destination": "/api/todos?id=:id" },
    { "source": "/api/todos", "destination": "/api/todos" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}
